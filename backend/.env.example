SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key
# PGRST002 / cache schema: par default pa gen boucle retry (rapid). Mete 1 pou re-essayer.
# SUPABASE_PGRST002_RETRY=1
# SUPABASE_MAX_ATTEMPTS=3
# Timeout HTTP global Supabase (leads, etc.) — segond
# SUPABASE_HTTP_TIMEOUT=45
# Timeout kout pou kreyasyon / listaj agents (default 6s)
# SUPABASE_AGENT_HTTP_TIMEOUT=6
# Kreyasyon agent: 1 = repons imedyat (lokal) + sync Supabase apre; 0 = eseye Supabase avan
# AGENT_CREATE_OFFLINE_FIRST=1
SUPABASE_AUTH_KEY=your-supabase-anon-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# Origines autorisees (credentials). Ne pas utiliser * seul. Localhost est toujours ajoute par le backend.
# Sur Koyeb: ajoute aussi ton domaine front (ex. Vercel) si different de localhost.
# CORS_ORIGINS=https://mon-app.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
TARGET_DOMAINS=math,sciences,langues,tech,business,developpement personnel
PROJECT_URL=https://www.konektegroup.com
PROJECT_SIGNUP_URL=https://www.konektegroup.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=contact@konektegroup.com
YOUTUBE_API_KEY=your-youtube-data-api-key
YOUTUBE_DISCOVERY_QUERIES=haitian educator,haitian coach,haitian teacher,kreyol edikasyon,haitian business coach
# Kategori pou dekouvèt nan cycle agent (YouTube + Apify) — menm familye ke rechèch milti-platfòm
# AGENT_YOUTUBE_CATEGORY=Edikasyon
# AGENT_DISCOVERY_CATEGORY=Edikasyon

# Vitès rechèch agent (Apify + YouTube « fast »)
# APIFY_WAIT_SECS=70
# TikTok actor clockworks/tiktok-scraper: kòd peyi proxy (egzanp None, US)
# APIFY_TIKTOK_PROXY_COUNTRY=None
# APIFY_TIKTOK_HASHTAGS_MAX=15
# APIFY_TIKTOK_RESULTS_PER_PAGE=50
# APIFY_TIKTOK_RESULTS_CAP=50
# AGENT_YOUTUBE_FAST=1
