# Copier vers .env.local (non versionne). CRA charge les variables REACT_APP_* au build.

# --- Rekòmandasyon dev ---
# Kite REACT_APP_API_URL VID pou itilize setupProxy.js: /api → http://127.0.0.1:8000 (backend lokal).
# Lanse backend: cd backend && python -m uvicorn server:app --reload --host 127.0.0.1 --port 8000
# REACT_APP_DEV_PROXY_TARGET=http://127.0.0.1:8000
# (Opsyonèl) Timeout proxy dev an ms — default 600000 (10 min), evite 504 sou rechèch Apify long.
# REACT_APP_DEV_PROXY_TIMEOUT_MS=600000

# Si .env.local gen yon URL Koyeb men ou vle dev lokal (proxy → backend sou machin ou): mete TRUE
# (axios ap itilize /api → proxy, epi li inyore REACT_APP_API_URL nan dev sèlman).
# REACT_APP_DEV_USE_LOCAL_PROXY=true

# Si ou mete yon URL absoli (Koyeb, etc.), axios pa pase pa proxy — se KOD sou sèvè sa a ki sèvi.
# REACT_APP_API_URL=https://ton-service.koyeb.app/api
REACT_APP_API_URL=